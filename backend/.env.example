# Copy to .env and fill in (or export directly in your shell / Railway project settings)

# Set ONE of these for real AI mood analysis, weekly advice, and affirmations.
# Groq is checked first if both are set. Without either, the app runs on local
# fallbacks (see README) — no code changes needed.
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Optional. Defaults to a local SQLite file (evolve.db). Set this to a Postgres
# connection string (e.g. from Railway's Postgres plugin or Neon) for persistence.
DATABASE_URL=
